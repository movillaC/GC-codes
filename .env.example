# Environment Configuration (Example)
# Copy this to .env and fill in your actual values
# DO NOT commit .env to git

# Flask Configuration
FLASK_ENV=development
SECRET_KEY=your-secret-key-change-in-production

# Gemini API Key (from https://console.cloud.google.com)
GEMINI_API_KEY=your-gemini-api-key-here

# Firebase Credentials (for production on Render)
# Get this from Firebase Console → Service Accounts → Generate new private key
# On Render, paste the entire JSON content as a single-line JSON string
FIREBASE_CREDENTIALS_JSON={"type":"service_account","project_id":"..."}
